# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/auth_db

# Redis
# Redis - NO PASSWORD (empty)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MOCK=false


# JWT
JWT_ACCESS_SECRET=4f8c3d9e1a7b2c6d8e9f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2
JWT_REFRESH_SECRET=9a7f2c1e6b3d4a8f5e2c9b1d7a6f3e0c4b8d2f1a9e6c3d7b5f8a2e1c9d6b4a7
ACCESS_TOKEN_EXPIRY=15m
